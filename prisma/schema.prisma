generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  displayName  String
  avatar       String    @default("✨")
  balance      Float     @default(1000)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  cartItems       CartItem[]
  orders          Order[]
  addresses       Address[]
  savedEras       SavedEra[]
  playlistTracks  PlaylistTrack[]
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  productId Int
  qty       Int     @default(1)
  name      String
  price     Float
  img       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Order {
  id        String      @id
  userId    String
  total     Float
  date      DateTime    @default(now())
  shipping  Json

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId Int
  qty       Int
  name      String
  price     Float
  img       String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String  @default("Home")
  name      String
  email     String
  address   String
  city      String
  zip       String
  country   String
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SavedEra {
  id          String    @id @default(cuid())
  userId      String
  eraId       String
  name        String
  year        Int
  accentColor String
  heroImage   String
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eraId])
  @@index([userId])
}

model PlaylistTrack {
  id          String  @id @default(cuid())
  userId      String
  trackId     String
  eraId       String
  eraName     String
  eraYear     Int
  accentColor String
  title       String
  audioSrc    String?
  albumArt    String?
  sortIndex   Int     @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId])
}
